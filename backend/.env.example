# ===========================================================================
# Turismo que se Sente — Backend environment variables
# Copy this file to ".env" and fill in real values. NEVER commit the real .env.
# ===========================================================================

# --- MongoDB connection (required) ---
# Connection string for the MongoDB instance.
MONGO_URL=mongodb://localhost:27017
# Database name used by the API.
DB_NAME=turismo_que_se_sente

# --- LLM integration (optional) ---
# Emergent LLM key used for automatic translations (OpenAI gpt-4o-mini).
# Leave empty to disable live translation.
EMERGENT_LLM_KEY=

# --- Security / Auth (required) ---
# Secret used to sign admin JWT tokens. Use a long, random, unique value.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# --- Default admin account (required) ---
# Seeded on first startup if no admin exists. Change the password after first login.
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=change-me-strong-password

# --- Cloudinary (required for /admin/upload-image) ---
# Image uploads are stored on Cloudinary (the host filesystem is ephemeral).
# Use EITHER the single CLOUDINARY_URL...
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=
# ...OR the three individual variables below (leave CLOUDINARY_URL empty if so):
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional: folder where uploads are organized in Cloudinary.
CLOUDINARY_UPLOAD_FOLDER=turismo-que-se-sente/uploads
